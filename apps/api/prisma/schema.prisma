generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  SUPER_ADMIN
  RESTAURANT_ADMIN
  OFITSIANT
  OSHPAZ
  KASSIR
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum RoomType {
  VIP
  ODDIY
  FAMILY
}

enum RoomStatus {
  BO_SH
  BAND
}

enum OrderStatus {
  YANGI
  TAYYORLANMOQDA
  TAYYOR
  TOPSHIRILDI
  YAKUNLANDI
}

enum PaymentMethod {
  NAQD
  KARTA
  CLICK
  PAYME
  UZUM_BANK
}

model Restaurant {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  phone            String
  address          String
  isBlocked        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  users            User[]
  rooms            Room[]
  tables           DiningTable[]
  categories       Category[]
  menuItems        MenuItem[]
  orders           Order[]
  payments         Payment[]
  subscriptions    Subscription[]
  receipts         Receipt[]
  activityLogs     ActivityLog[]
}

model User {
  id           String       @id @default(cuid())
  fullName     String
  phone        String       @unique
  passwordHash String
  role         PlatformRole
  restaurantId String?
  createdAt    DateTime     @default(now())
  restaurant   Restaurant?  @relation(fields: [restaurantId], references: [id])
  waiterOrders Order[]      @relation("WaiterOrders")
  chefOrders   Order[]      @relation("ChefOrders")
  payments     Payment[]
  receipts     Receipt[]
}

model SubscriptionPlan {
  id          String         @id @default(cuid())
  name        String
  monthlyUzs  Int
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  subscriptions Subscription[]
}

model Subscription {
  id               String             @id @default(cuid())
  restaurantId     String
  subscriptionPlanId String
  startDate        DateTime
  endDate          DateTime
  status           SubscriptionStatus
  createdAt        DateTime           @default(now())
  restaurant       Restaurant         @relation(fields: [restaurantId], references: [id])
  plan             SubscriptionPlan   @relation(fields: [subscriptionPlanId], references: [id])
}

model Room {
  id            String      @id @default(cuid())
  name          String
  type          RoomType
  status        RoomStatus  @default(BO_SH)
  restaurantId  String
  createdAt     DateTime    @default(now())
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id])
  tables        DiningTable[]
  orders        Order[]
}

model DiningTable {
  id            String      @id @default(cuid())
  number        Int
  qrCode        String
  isActive      Boolean     @default(false)
  roomId        String
  restaurantId  String
  room          Room        @relation(fields: [roomId], references: [id])
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id])
  orders        Order[]

  @@unique([restaurantId, number])
}

model Category {
  id            String      @id @default(cuid())
  name          String
  slug          String
  restaurantId  String
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id])
  menuItems     MenuItem[]

  @@unique([restaurantId, slug])
}

model MenuItem {
  id            String      @id @default(cuid())
  name          String
  description   String
  imageUrl      String
  priceUzs      Int
  isAvailable   Boolean     @default(true)
  restaurantId  String
  categoryId    String
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id])
  category      Category    @relation(fields: [categoryId], references: [id])
  orderItems    OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  restaurantId  String
  roomId        String
  tableId       String
  waiterId      String?
  chefId        String?
  status        OrderStatus @default(YANGI)
  totalUzs      Int         @default(0)
  isPaid        Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id])
  room          Room        @relation(fields: [roomId], references: [id])
  table         DiningTable @relation(fields: [tableId], references: [id])
  waiter        User?       @relation("WaiterOrders", fields: [waiterId], references: [id])
  chef          User?       @relation("ChefOrders", fields: [chefId], references: [id])
  items         OrderItem[]
  payment       Payment?
}

model OrderItem {
  id          String    @id @default(cuid())
  orderId     String
  menuItemId  String
  quantity    Int
  priceUzs    Int
  order       Order     @relation(fields: [orderId], references: [id])
  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id])
}

model Payment {
  id            String        @id @default(cuid())
  restaurantId  String
  orderId       String        @unique
  cashierId     String?
  method        PaymentMethod
  amountUzs     Int
  paidAt        DateTime      @default(now())
  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id])
  order         Order         @relation(fields: [orderId], references: [id])
  cashier       User?         @relation(fields: [cashierId], references: [id])
  receipt       Receipt?
}

model Receipt {
  id            String      @id @default(cuid())
  restaurantId  String
  paymentId     String      @unique
  cashierId     String?
  receiptNo     String      @unique
  payloadJson   Json
  createdAt     DateTime    @default(now())
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id])
  payment       Payment     @relation(fields: [paymentId], references: [id])
  cashier       User?       @relation(fields: [cashierId], references: [id])
}

model ActivityLog {
  id            String      @id @default(cuid())
  restaurantId  String
  userId        String?
  action        String
  meta          Json?
  createdAt     DateTime    @default(now())
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id])
}
